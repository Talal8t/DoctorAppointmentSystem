@{
    ViewData["Title"] = "Doctor Appointment Management System";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
    }

    .container {
        text-align: center;
        margin-top: 100px;
    }

    h1 {
        font-size: 40px;
        margin-bottom: 10px;
    }

    p {
        color: #cbd5f5;
    }

    .btn-group {
        margin-top: 30px;
    }

    .btn {
        padding: 12px 25px;
        margin: 10px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
        text-decoration: none;
        color: white;
        transition: 0.3s;
    }

    .btn-login {
        background: #3b82f6;
    }

        .btn-login:hover {
            background: #2563eb;
        }

    .btn-register {
        background: #10b981;
    }

        .btn-register:hover {
            background: #059669;
        }

    footer {
        position: fixed;
        bottom: 10px;
        width: 100%;
        text-align: center;
        font-size: 14px;
        color: #94a3b8;
    }
</style>

<div class="container">
    <h1>Doctor Appointment Management System</h1>
    <p>Manage appointments, doctors, patients and real-time chat efficiently.</p>

    <div class="btn-group">
        <a href="/Auth/Login" class="btn btn-login">Login</a>
        <a href="/Auth/Register" class="btn btn-register">Register</a>
    </div>
</div>

<footer>
    Built by Talal Tariq, Hamid Tahir, Tayyab Ahmad
</footer>