@model DAMS.Models.Appointment
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
}

<style>
    .page-title {
        text-align: center;
        margin-bottom: 25px;
    }

    .form-container {
        width: 95%;
        margin: auto;
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0px 2px 10px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 15px;
    }

    select, input[type="date"] {
        width: 100%;
        max-width: 400px;
        padding: 8px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .hidden-section {
        display: none;
    }

    .info-msg {
        color: #555;
        font-style: italic;
        margin-top: 10px;
    }

    .btn-main {
        margin-top: 15px;
        padding: 10px 15px;
        background: #0ea5e9;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

        .btn-main:hover {
            background: #0284c7;
        }

    .slot-btn {
        padding: 6px 12px;
        border: 1px solid #ccc;
        background: white;
        cursor: pointer;
        border-radius: 5px;
    }

    .selected-slot {
        background-color: #38bdf8 !important;
        color: white !important;
        border: 2px solid #0284c7 !important;
    }

    .table-container {
        width: 100%;
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0px 4px 20px rgba(0,0,0,0.08);
        animation: fadeIn 0.4s ease-in-out;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-family: Arial, sans-serif;
    }

    th {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        padding: 14px;
        text-align: left;
        font-size: 14px;
    }

    td {
        padding: 14px;
        border-bottom: 1px solid #eee;
        transition: background 0.2s ease;
    }

    tr:hover {
        background-color: #f1f5f9;
        transform: scale(1.01);
        transition: 0.2s ease;
    }

    /* STATUS BADGES */
    .status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
        display: inline-block;
    }

    .booked {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .cancelled {
        background: #fee2e2;
        color: #b91c1c;
    }

    /* BUTTON */
    .slot-btn {
        padding: 6px 14px;
        border-radius: 6px;
        border: 1px solid #ccc;
        background: white;
        cursor: pointer;
        transition: all 0.25s ease;
    }

        .slot-btn:hover {
            background: #0ea5e9;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0px 3px 10px rgba(14,165,233,0.3);
        }

    /* SELECTED SLOT */
    .selected-slot {
        background: #38bdf8 !important;
        color: white !important;
        border: 2px solid #0284c7 !important;
        transform: scale(1.05);
    }

    /* FADE IN ANIMATION */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<h2 class="page-title">Book Appointment</h2>

<div class="form-container">
    <div style="max-width:500px;">
        <form method="post">

            <!-- 🔹 Department -->
            <div class="form-group">
                <label>Department</label>
                <select id="DepartmentId" name="DepartmentId" onchange="loadDoctors()">
                    <option value="">Select Department</option>

                    @foreach (var dept in ViewBag.Departments)
                    {
                        <option value="@dept.DepartmentId">@dept.DepartmentName</option>
                    }
                </select>

                <p class="info-msg">Please select a department</p>
            </div>

            <!-- 🔹 Doctor -->
            <div id="doctorSection" class="form-group hidden-section">
                <label>Doctor</label>
                <select id="DoctorId" name="DoctorId" onchange="loadSlots()">
                    <option value="">Select Doctor</option>
                </select>

                <p class="info-msg">Please select a doctor</p>
            </div>

            <!-- 🔹 Appointment Section -->
            <div id="appointmentSection" class="hidden-section">

                <div class="form-group">
                    <label>Date</label>
                    <input asp-for="AppointmentDate"
                           type="date"
                           id="appointmentDate"
                           onchange="loadSlots()" />
                </div>

                <h3>Available Slots</h3>

                <div id="slotContainer">
                    <p class="info-msg">Select a date to see available slots</p>
                </div>

                <!-- Hidden slot -->
                <input type="hidden" asp-for="SlotId" id="SlotId" />

                <button type="submit" class="btn-main">Book Appointment</button>
            </div>

        </form>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}

@section scripts {
    <script>

        function loadDoctors() {
            var deptId = document.getElementById("DepartmentId").value;

            if (!deptId) return;

            fetch('/Patient/GetDoctorsByDepartment?departmentId=' + deptId)
                .then(res => res.text())
                .then(data => {
                    document.getElementById("DoctorId").innerHTML = data;

                    document.getElementById("doctorSection").style.display = "block";
                    document.getElementById("appointmentSection").style.display = "none";
                });
        }

        function loadSlots() {
            var doctorId = document.getElementById("DoctorId").value;
            var date = document.getElementById("appointmentDate").value;

            if (!doctorId) return;

            document.getElementById("appointmentSection").style.display = "block";

            if (!date) return;

            fetch(`/Patient/GetSlots?doctorId=${doctorId}&date=${date}`)
                .then(res => res.text())
                .then(data => {
                    document.getElementById("slotContainer").innerHTML = data;
                });
        }

        let selectedSlotId = null;

        function selectSlot(slotId) {

            selectedSlotId = slotId;
            document.getElementById("SlotId").value = slotId;

            document.querySelectorAll(".slot-btn").forEach(btn => {
                btn.classList.remove("selected-slot");s
            });

            let btn = document.getElementById("slot-" + slotId);
            if (btn) {
                btn.classList.add("selected-slot");
            }
        }

        // prevent past dates
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("appointmentDate").min =
                new Date().toISOString().split("T")[0];
        });

    </script>
}