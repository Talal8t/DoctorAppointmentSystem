<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Doctor Panel</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
            body {
                margin: 0;
                font-family: Arial;
                background: #f4f6fb;
                overflow-x: hidden;
            }

            /* ================= SIDEBAR ================= */
            .sidebar {
                width: 230px;
                height: 100vh;
                background: #0f172a;
                color: white;
                position: fixed;
                top: 0;
                left: 0;
                padding-top: 20px;
            }

                .sidebar h2 {
                    text-align: center;
                    margin-bottom: 25px;
                }

                .sidebar a {
                    display: block;
                    padding: 12px 18px;
                    color: white;
                    text-decoration: none;
                }

                    .sidebar a:hover {
                        background: #1e293b;
                    }

            /* ================= MAIN AREA ================= */
            .main {
                margin-left: 230px;
                padding: 20px;
            }

            /* ================= TOPBAR ================= */
            .topbar {
                background: white;
                padding: 12px 20px;
                border-radius: 10px;
                margin-bottom: 20px;
                box-shadow: 0px 2px 6px rgba(0,0,0,0.08);
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            /* ================= NOTIFICATION ================= */
            .topbar-right {
                display: flex;
                align-items: center;
                gap: 15px;
                position: relative;
            }

            .notification-wrapper {
                position: relative;
            }

            .bell {
                cursor: pointer;
                font-size: 20px;
                position: relative;
            }

            .notif-count {
                position: absolute;
                top: -6px;
                right: -10px;
                background: red;
                color: white;
                font-size: 11px;
                padding: 2px 6px;
                border-radius: 50%;
            }

            .notif-dropdown {
                display: none;
                position: absolute;
                right: 0;
                top: 30px;
                width: 280px;
                background: white;
                border-radius: 10px;
                box-shadow: 0px 4px 12px rgba(0,0,0,0.15);
                padding: 10px;
                z-index: 999;
            }

            .notification-item {
                padding: 8px;
                border-bottom: 1px solid #eee;
                font-size: 14px;
            }

                .notification-item:hover {
                    background: #f1f5f9;
                }

            .mark-btn {
                width: 100%;
                margin-top: 8px;
                padding: 6px;
                background: #0ea5e9;
                border: none;
                color: white;
                border-radius: 6px;
                cursor: pointer;
            }

            /* ================= LOGOUT ================= */
            .logout-btn {
                background: #ef4444;
                border: none;
                padding: 8px 12px;
                color: white;
                border-radius: 6px;
                cursor: pointer;
            }
    </style>

    <script>
            function toggleNotifications() {
                const dropdown = document.getElementById("notifDropdown");
                dropdown.style.display =
                    dropdown.style.display === "block" ? "none" : "block";
            }

            function loadNotifications() {
                fetch('/Notification/GetNotifications')
                    .then(r => r.text())
                    .then(html => {
                        document.getElementById("notifContainer").innerHTML = html;
                    });

                fetch('/Notification/GetCount')
                    .then(r => r.text())
                    .then(count => {
                        document.getElementById("notifCount").innerText = count;
                    });
            }

            function markAllRead() {
                fetch('/Notification/MarkRead', { method: 'POST' })
                    .then(() => loadNotifications());
            }

            setInterval(loadNotifications, 3000);
            loadNotifications();
    </script>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h2>Doctor</h2>

        <a href="/Doctor/Dashboard">📊 Dashboard</a>
        <a href="/Doctor/ManageSlots">📅 Manage Slots</a>
        <a href="/Doctor/Appointments">📋 Appointments</a>
        <a href="/Message/Chat?broadcastTarget=todayPatients">💬 Message Today's Patients</a>
        <a href="/Message/Broadcasts">📢 Broadcast Messages</a>

        <hr />

        <form method="post" action="/Auth/Logout" style="padding: 0 18px;">
            <button class="logout-btn" style="width:100%;">Logout</button>
        </form>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOPBAR -->
        <div class="topbar">

            <div><strong>Doctor Panel</strong></div>

            <div class="topbar-right">

                <!-- 🔔 Notification -->
                <div class="notification-wrapper">

                    <div class="bell" onclick="toggleNotifications()">
                        🔔
                        <span id="notifCount" class="notif-count">0</span>
                    </div>

                    <div id="notifDropdown" class="notif-dropdown">
                        <div id="notifContainer">Loading...</div>

                        <button onclick="markAllRead()" class="mark-btn">
                            Mark all as read
                        </button>
                    </div>

                </div>

            </div>

        </div>

        @RenderBody()

    </div>

</body>
</html>
