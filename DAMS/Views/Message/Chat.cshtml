@model DAMS.ViewModels.ChatViewModel

@{
    Layout = Model.CurrentRole == "Admin"
        ? "~/Views/Shared/_AdminLayout.cshtml"
        : Model.CurrentRole == "Doctor"
            ? "~/Views/Shared/_DoctorLayout.cshtml"
            : "~/Views/Shared/_PatientLayout.cshtml";
}

<style>
    body {
        background: #f5f7fb;
        font-family: Arial, sans-serif;
    }

    .chat-container {
        width: min(920px, 94vw);
        margin: 28px auto;
        background: #ffffff;
        border: 1px solid #dbe3ef;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        height: 78vh;
        overflow: hidden;
    }

    .chat-header {
        background: #12355b;
        color: white;
        padding: 16px 18px;
        font-size: 18px;
        font-weight: 700;
    }

    .chat-subtitle {
        color: #d7e5f4;
        display: block;
        font-size: 12px;
        font-weight: 400;
        margin-top: 4px;
    }

    .chat-box {
        flex: 1;
        padding: 18px;
        overflow-y: auto;
        background: #f8fafc;
    }

    .message {
        max-width: 68%;
        padding: 10px 14px;
        margin: 8px 0;
        border-radius: 8px;
        font-size: 14px;
        line-height: 1.45;
        overflow-wrap: anywhere;
    }

    .sent {
        background: #1769aa;
        color: white;
        margin-left: auto;
        text-align: right;
    }

    .received {
        background: #e7edf5;
        color: #142033;
        margin-right: auto;
    }

    .meta {
        display: block;
        font-size: 11px;
        opacity: .78;
        margin-top: 5px;
    }

    .chat-input {
        display: flex;
        gap: 10px;
        padding: 12px;
        border-top: 1px solid #dbe3ef;
        background: #ffffff;
    }

    .chat-input input {
        flex: 1;
        min-width: 0;
        padding: 10px 12px;
        border: 1px solid #bac8d9;
        border-radius: 6px;
        outline: none;
    }

    .chat-input button {
        padding: 10px 18px;
        background: #1f7a4d;
        border: none;
        color: white;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 700;
    }

    .chat-input button:disabled {
        background: #91a3b4;
        cursor: default;
    }
</style>

<div class="chat-container">
    <div class="chat-header">
        @Model.Title
        <span class="chat-subtitle">@Model.Mode</span>
    </div>

    <input type="hidden" id="doctorId" value="@Model.DoctorId" />
    <input type="hidden" id="patientId" value="@Model.PatientId" />
    <input type="hidden" id="broadcastTarget" value="@Model.BroadcastTarget" />
    <input type="hidden" id="mode" value="@Model.Mode" />
    <input type="hidden" id="currentUserId" value="@Model.CurrentUserId" />

    <div class="chat-box" id="chatBox">
        @foreach (var msg in Model.Messages)
        {
            <div class="message @(msg.SenderId == Model.CurrentUserId ? "sent" : "received")">
                @msg.Content
                <span class="meta">@msg.CreatedAt.ToString("MMM dd, h:mm tt")</span>
            </div>
        }
    </div>

    <div class="chat-input">
        <input type="text" id="msgInput" placeholder="Type a message..." autocomplete="off" />
        <button type="button" id="sendBtn" onclick="sendMessage()">Send</button>
    </div>
</div>

<script>
    const chatBox = document.getElementById("chatBox");
    let lastRenderedKey = "";
    chatBox.scrollTop = chatBox.scrollHeight;

    async function sendMessage() {
        const input = document.getElementById("msgInput");
        const button = document.getElementById("sendBtn");
        const content = input.value.trim();

        if (!content) return;

        button.disabled = true;

        const response = await fetch('/Message/Send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                mode: document.getElementById("mode").value,
                doctorId: parseNullableInt(document.getElementById("doctorId").value),
                patientId: parseNullableInt(document.getElementById("patientId").value),
                broadcastTarget: document.getElementById("broadcastTarget").value || null,
                content: content
            })
        });

        button.disabled = false;

        if (!response.ok) {
            alert(await response.text());
            return;
        }

        input.value = "";
        await loadMessages();
    }

    function parseNullableInt(value) {
        return value ? parseInt(value, 10) : null;
    }

    async function loadMessages() {
        const query = new URLSearchParams();
        const doctorId = document.getElementById("doctorId").value;
        const patientId = document.getElementById("patientId").value;
        const broadcastTarget = document.getElementById("broadcastTarget").value;

        if (doctorId) query.append("doctorId", doctorId);
        if (patientId) query.append("patientId", patientId);
        if (broadcastTarget) query.append("broadcastTarget", broadcastTarget);

        const response = await fetch(`/Message/Messages?${query.toString()}`);

        if (!response.ok) return;

        const messages = await response.json();
        renderMessages(messages);
    }

    function renderMessages(messages) {
        const nextKey = messages.map(message => message.messageId).join(",");
        if (nextKey === lastRenderedKey) return;

        lastRenderedKey = nextKey;
        const currentUserId = parseInt(document.getElementById("currentUserId").value, 10);

        chatBox.innerHTML = "";

        messages.forEach(message => {
            const item = document.createElement("div");
            item.className = `message ${message.senderId === currentUserId ? "sent" : "received"}`;
            item.innerHTML = `${escapeHtml(message.content)}<span class="meta">${escapeHtml(message.createdAt)}</span>`;
            chatBox.appendChild(item);
        });

        chatBox.scrollTop = chatBox.scrollHeight;
    }

    function escapeHtml(value) {
        const div = document.createElement("div");
        div.innerText = value;
        return div.innerHTML;
    }

    document.getElementById("msgInput").addEventListener("keydown", function (event) {
        if (event.key === "Enter") {
            event.preventDefault();
            sendMessage();
        }
    });

    loadMessages();
    setInterval(loadMessages, 3000);
</script>
